STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
STAGED_FRONTEND_FORMATTABLE_FILES=$(echo "$STAGED_FILES" | grep -E '^FoodDiary\.Web\.Client/(src|projects)/.*\.(ts|html)$' || true)

HAS_TS=$(echo "$STAGED_FILES" | grep -c '\.ts$' || true)
HAS_HTML=$(echo "$STAGED_FILES" | grep -c '\.html$' || true)
HAS_SCSS=$(echo "$STAGED_FILES" | grep -c '\.scss$' || true)
HAS_FRONTEND=$(echo "$STAGED_FILES" | grep -c '^FoodDiary\.Web\.Client/' || true)
HAS_FRONTEND_SHARED=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/(package(-lock)?\.json|angular\.json|tsconfig.*\.json|src/(styles|test-setup)\.ts|src/styles/|src/styles\.scss)' || true)
HAS_FRONTEND_APP=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/(src/app|assets/|src/environments|src/main|src/server|src/app\.|src/index\.html|src/manifest\.webmanifest|ngsw-config\.json)' || true)
HAS_FRONTEND_UI_KIT=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/projects/fd-ui-kit/' || true)
HAS_FRONTEND_ADMIN=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/projects/fooddiary-admin/' || true)
HAS_FRONTEND_DEPS=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/(src/app/|projects/(fooddiary-admin/src/app|fd-ui-kit/src/lib)/|package(-lock)?\.json|\.dependency-cruiser(-known-violations\.json|\.cjs))' || true)
HAS_I18N=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/(assets/i18n/.*\.json|scripts/check-i18n\.mjs|package\.json|src/.*\.html)$' || true)
HAS_STORYBOOK=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Web\.Client/(\.storybook/.*|projects/fd-ui-kit/src/.*\.stories\.(ts|mdx)|package\.json|angular\.json)$' || true)
HAS_CS=$(echo "$STAGED_FILES" | grep -c '\.cs$' || true)
HAS_API_CONTRACT=$(echo "$STAGED_FILES" | grep -Ec '^(FoodDiary\.Web\.Api/|FoodDiary\.Presentation\.Api/|FoodDiary\.Contracts/|tests/FoodDiary\.Web\.Api\.IntegrationTests/|tests/FoodDiary\.Web\.Api\.IntegrationTests/Snapshots/)' || true)
HAS_INFRA_MIGRATIONS=$(echo "$STAGED_FILES" | grep -Ec '^FoodDiary\.Infrastructure/Migrations/.*\.cs$' || true)

cd FoodDiary.Web.Client

if [ "$HAS_TS" -gt 0 ] || [ "$HAS_HTML" -gt 0 ]; then
  echo "=== Running Prettier ==="
  if [ -n "$STAGED_FRONTEND_FORMATTABLE_FILES" ]; then
    printf '%s\n' "$STAGED_FRONTEND_FORMATTABLE_FILES" | sed 's#^FoodDiary\.Web\.Client/##' | xargs -n 50 npx prettier --check || exit 1
  else
    echo "=== Skipping Prettier (no frontend .ts/.html files changed) ==="
  fi
else
  echo "=== Skipping Prettier (no formattable files changed) ==="
fi

if [ "$HAS_TS" -gt 0 ]; then
  echo "=== Running ESLint ==="
  npm run lint || exit 1
else
  echo "=== Skipping ESLint (no .ts files changed) ==="
fi

if [ "$HAS_SCSS" -gt 0 ]; then
  echo "=== Running Stylelint ==="
  npm run stylelint || exit 1
else
  echo "=== Skipping Stylelint (no .scss files changed) ==="
fi

if [ "$HAS_FRONTEND_DEPS" -gt 0 ]; then
  echo "=== Running frontend dependency graph lint ==="
  npm run lint:deps || exit 1
else
  echo "=== Skipping frontend dependency graph lint (no dependency-relevant frontend files changed) ==="
fi

if [ "$HAS_I18N" -gt 0 ]; then
  echo "=== Running i18n consistency check ==="
  npm run check:i18n || exit 1
else
  echo "=== Skipping i18n consistency check (no locale files changed) ==="
fi

if [ "$HAS_FRONTEND" -gt 0 ]; then
  echo "=== Running frontend tests ==="
  if [ "$HAS_FRONTEND_SHARED" -gt 0 ] || [ "$HAS_FRONTEND_UI_KIT" -gt 0 ]; then
    echo "=== Running all frontend tests (shared or UI kit changes) ==="
    npm run test:ci || exit 1
  else
    if [ "$HAS_FRONTEND_APP" -gt 0 ]; then
      echo "=== Running app frontend tests ==="
      npm run test:ci:app || exit 1
    fi

    if [ "$HAS_FRONTEND_ADMIN" -gt 0 ]; then
      echo "=== Running admin frontend tests ==="
      npm run test:ci:admin || exit 1
    fi

    if [ "$HAS_FRONTEND_APP" -eq 0 ] && [ "$HAS_FRONTEND_ADMIN" -eq 0 ]; then
      echo "=== Running all frontend tests (unclassified frontend changes) ==="
      npm run test:ci || exit 1
    fi
  fi
else
  echo "=== Skipping frontend tests (no frontend files changed) ==="
fi

if [ "$HAS_STORYBOOK" -gt 0 ]; then
  echo "=== Running Storybook build ==="
  npm run build:storybook || exit 1
else
  echo "=== Skipping Storybook build (no Storybook files changed) ==="
fi

cd ..

if [ "$HAS_CS" -gt 0 ]; then
  echo "=== Running backend solution build ==="
  dotnet build FoodDiary.slnx --no-restore || exit 1

  echo "=== Running dotnet format check ==="
  STAGED_CS_FILES=$(echo "$STAGED_FILES" | grep '\.cs$' | tr '\n' ',' | sed 's/,$//')
  dotnet format FoodDiary.slnx --verify-no-changes --include "$STAGED_CS_FILES" 2>&1 | grep "error" && { echo "Run 'dotnet format FoodDiary.slnx' to fix formatting."; exit 1; } || true
else
  echo "=== Skipping dotnet format (no .cs files changed) ==="
fi

if [ "$HAS_INFRA_MIGRATIONS" -gt 0 ]; then
  echo "=== Running infrastructure migration build guard ==="
  dotnet build FoodDiary.Infrastructure/FoodDiary.Infrastructure.csproj --no-restore || exit 1
else
  echo "=== Skipping infrastructure migration build guard (no migration files changed) ==="
fi

if [ "$HAS_CS" -gt 0 ]; then
  echo "=== Running backend tests ==="
  dotnet test tests/FoodDiary.Application.Tests/FoodDiary.Application.Tests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.ArchitectureTests/FoodDiary.ArchitectureTests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.Infrastructure.Tests/FoodDiary.Infrastructure.Tests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.JobManager.Tests/FoodDiary.JobManager.Tests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.MailInbox.Tests/FoodDiary.MailInbox.Tests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.MailRelay.Tests/FoodDiary.MailRelay.Tests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.Presentation.Api.Tests/FoodDiary.Presentation.Api.Tests.csproj --no-restore --no-build || exit 1
  dotnet test tests/FoodDiary.Telegram.Bot.Tests/FoodDiary.Telegram.Bot.Tests.csproj --no-restore --no-build || exit 1
else
  echo "=== Skipping backend tests (no .cs files changed) ==="
fi

if [ "$HAS_API_CONTRACT" -gt 0 ]; then
  echo "=== Running API contract integration tests ==="
  dotnet test tests/FoodDiary.Web.Api.IntegrationTests/FoodDiary.Web.Api.IntegrationTests.csproj --no-restore --no-build --filter "FullyQualifiedName~PresentationBoundaryIntegrationTests|FullyQualifiedName~PresentationPayloadContractIntegrationTests" || exit 1
else
  echo "=== Skipping API contract integration tests (no API contract files changed) ==="
fi
