{
    "name": "food-diary-web-client",
    "version": "0.0.0",
    "type": "module",
    "overrides": {
        "@angular-devkit/build-angular": {
            "@babel/core": "7.29.7",
            "http-proxy-middleware": "3.0.7",
            "webpack-dev-server": "5.2.5"
        },
        "@angular/build": {
            "@babel/core": "7.29.7"
        },
        "@microsoft/signalr": {
            "ws": "7.5.11"
        },
        "hono": "4.12.27",
        "jsdom": {
            "undici": "7.28.0"
        },
        "lighthouse": {
            "ws": "7.5.11"
        },
        "minimatch": "^9.0.5",
        "tmp": "^0.2.7",
        "uuid": "^11.1.1",
        "websocket-driver": "0.7.5",
        "vite": {
            "esbuild": "0.28.1"
        },
        "webpack-dev-server": "^5.2.5",
        "webpack-dev-server@5.2.5": {
            "http-proxy-middleware": "2.0.10"
        }
    },
    "scripts": {
        "prepare": "cd .. && husky FoodDiary.Web.Client/.husky",
        "ng": "ng",
        "build": "node scripts/generate-legacy-i18n.mjs && ng build && node scripts/generate-ru-prerender-html.mjs",
        "build:prod": "node scripts/generate-legacy-i18n.mjs && ng build --configuration=production && node scripts/generate-ru-prerender-html.mjs",
        "build:audit": "node scripts/generate-legacy-i18n.mjs && ng build --configuration=audit && node scripts/generate-ru-prerender-html.mjs",
        "build:staging": "node scripts/generate-legacy-i18n.mjs && ng build --configuration=staging && node scripts/generate-ru-prerender-html.mjs",
        "build:admin": "ng build fooddiary-admin",
        "build:tour": "ng build fd-tour",
        "start": "ng serve --configuration=development",
        "start:tunnel": "ng serve --configuration=tunnel",
        "tunnel": "cloudflared tunnel run fooddiary-local",
        "start:tunnel:all": "concurrently -k -n web,tunnel -c green,blue \"npm:start:tunnel\" \"npm:tunnel\"",
        "start:prod": "ng serve --configuration=production",
        "start:staging": "ng serve --configuration=staging",
        "start:admin": "ng serve fooddiary-admin",
        "watch": "ng build --watch --configuration development",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:deps": "depcruise --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json src/app projects/fooddiary-admin/src/app projects/fd-ui-kit/src/lib projects/fd-tour/src/lib",
        "lint:deps:strict": "depcruise --config .dependency-cruiser.cjs src/app projects/fooddiary-admin/src/app projects/fd-ui-kit/src/lib projects/fd-tour/src/lib",
        "check:depcruise-baseline": "node scripts/check-depcruise-baseline.mjs",
        "check:component-logic": "node scripts/check-component-logic.mjs",
        "check:state-ownership": "node --test scripts/check-state-ownership.test.mjs && node scripts/check-state-ownership.mjs",
        "check:format:ci": "prettier --check \"src/**/*.{ts,html}\" \"projects/**/*.{ts,html}\"",
        "verify": "npm run lint && npm run lint:deps:strict && npm run check:depcruise-baseline && npm run check:component-logic && npm run check:state-ownership && npm run stylelint && npm run audit:design-tokens && npm run build && npm run build:admin && npm run build:tour && npm run check:seo-prerender && npm run test:ci:app && npm run test:ci:ui-kit && npm run test:ci:tour && npm run test:ci:admin && npm run check:i18n",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "stylelint '**/*.{css,scss}' --fix",
        "prettier": "prettier --check '**/*.{js,ts,css,scss,html,json,md}'",
        "prettier:fix": "prettier --write '**/*.{js,ts,css,scss,html,json,md}'",
        "test": "ng test",
        "test:ci": "ng test --watch=false",
        "test:ci:app": "ng test food-diary-web-client --watch=false",
        "test:ci:ui-kit": "ng test fd-ui-kit --watch=false",
        "test:ci:tour": "ng test fd-tour --watch=false",
        "test:ci:admin": "ng test fooddiary-admin --watch=false",
        "test:coverage": "npm run test:coverage:app && npm run test:coverage:ui-kit && npm run test:coverage:admin",
        "test:coverage:app": "ng test food-diary-web-client --watch=false --coverage",
        "test:coverage:ui-kit": "ng test fd-ui-kit --watch=false --coverage",
        "test:coverage:tour": "ng test fd-tour --watch=false --coverage",
        "test:coverage:admin": "ng test fooddiary-admin --watch=false --coverage",
        "check:i18n": "node scripts/check-i18n.mjs",
        "check:seo-prerender": "node scripts/check-prerender-html.mjs",
        "test:e2e:client:smoke": "npx playwright test -c playwright.client.smoke.config.ts",
        "test:e2e:client:accessibility": "npx playwright test -c playwright.client.smoke.config.ts --grep \"authenticated accessibility\"",
        "test:e2e:client:smoke:ui": "npx playwright test -c playwright.client.smoke.config.ts --ui",
        "test:e2e:admin:smoke": "npx playwright test -c playwright.admin.smoke.config.ts",
        "test:e2e:admin:smoke:ui": "npx playwright test -c playwright.admin.smoke.config.ts --ui",
        "audit:lighthouse:collect": "node scripts/run-lighthouse.mjs",
        "audit:lighthouse": "npm run build:audit && npm run audit:lighthouse:collect",
        "audit:design-tokens": "node scripts/audit-design-tokens.mjs",
        "storybook": "ng run fd-ui-kit:storybook",
        "build:storybook": "ng run fd-ui-kit:build-storybook",
        "serve:ssr:food-diary-web-client": "node dist/server/server.mjs"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^22.0.7",
        "@angular/cdk": "^22.0.5",
        "@angular/common": "^22.0.7",
        "@angular/compiler": "^22.0.7",
        "@angular/core": "^22.0.7",
        "@angular/forms": "^22.0.7",
        "@angular/platform-browser": "^22.0.7",
        "@angular/platform-browser-dynamic": "^22.0.7",
        "@angular/platform-server": "^22.0.7",
        "@angular/router": "^22.0.7",
        "@angular/service-worker": "^22.0.7",
        "@angular/ssr": "^22.0.7",
        "@microsoft/signalr": "^10.0.0",
        "@ngx-translate/core": "^18.0.0",
        "@ngx-translate/http-loader": "^18.0.0",
        "express": "^5.2.1",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^22.0.7",
        "@angular-eslint/eslint-plugin": "^22.1.0",
        "@angular-eslint/eslint-plugin-template": "^22.1.0",
        "@angular-eslint/template-parser": "^22.1.0",
        "@angular/build": "^22.0.0",
        "@angular/cli": "^22.0.7",
        "@angular/compiler-cli": "^22.0.7",
        "@axe-core/playwright": "^4.12.1",
        "@emnapi/core": "^1.11.2",
        "@emnapi/runtime": "^1.11.2",
        "@emnapi/wasi-threads": "^2.0.1",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@lhci/cli": "^0.15.1",
        "@material-design-icons/font": "^0.14.15",
        "@playwright/test": "^1.61.1",
        "@storybook/angular": "^10.5.2",
        "@types/express": "^5.0.6",
        "@types/node": "^26.1.1",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "@vitest/coverage-v8": "^4.1.10",
        "angular-eslint": "^22.1.0",
        "baseline-browser-mapping": "^2.10.43",
        "concurrently": "^10.0.3",
        "dependency-cruiser": "^18.1.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-boundaries": "^7.0.2",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-rxjs-x": "^1.0.2",
        "eslint-plugin-security": "^4.0.1",
        "eslint-plugin-simple-import-sort": "^14.0.0",
        "eslint-plugin-sonarjs": "^4.2.0",
        "eslint-plugin-storybook": "10.5.2",
        "eslint-plugin-unicorn": "^72.0.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "ng-morph": "^5.0.1",
        "ng-packagr": "^22.0.1",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.9.5",
        "storybook": "^10.5.2",
        "stylelint": "^17.14.1",
        "stylelint-config-clean-order": "^10.0.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-scss": "^7.2.0",
        "typescript": "6.0.3",
        "vitest": "^4.1.10"
    }
}
