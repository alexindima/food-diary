{
    "name": "food-diary-web-client",
    "version": "0.0.0",
    "type": "module",
    "overrides": {
        "minimatch": "^9.0.5",
        "tmp": "^0.2.7",
        "uuid": "^11.1.1",
        "webpack-dev-server": "^5.2.4"
    },
    "scripts": {
        "prepare": "cd .. && husky FoodDiary.Web.Client/.husky",
        "ng": "ng",
        "build": "ng build && node scripts/generate-ru-prerender-html.mjs",
        "build:prod": "ng build --configuration=production && node scripts/generate-ru-prerender-html.mjs",
        "build:audit": "ng build --configuration=audit && node scripts/generate-ru-prerender-html.mjs",
        "build:staging": "ng build --configuration=staging && node scripts/generate-ru-prerender-html.mjs",
        "build:admin": "ng build fooddiary-admin",
        "start": "ng serve --configuration=development",
        "start:tunnel": "ng serve --configuration=tunnel",
        "tunnel": "cloudflared tunnel run fooddiary-local",
        "start:tunnel:all": "concurrently -k -n web,tunnel -c green,blue \"npm:start:tunnel\" \"npm:tunnel\"",
        "start:prod": "ng serve --configuration=production",
        "start:staging": "ng serve --configuration=staging",
        "start:admin": "ng serve fooddiary-admin",
        "watch": "ng build --watch --configuration development",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:deps": "depcruise --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json src/app projects/fooddiary-admin/src/app projects/fd-ui-kit/src/lib",
        "lint:deps:strict": "depcruise --config .dependency-cruiser.cjs src/app projects/fooddiary-admin/src/app projects/fd-ui-kit/src/lib",
        "check:depcruise-baseline": "node scripts/check-depcruise-baseline.mjs",
        "verify": "npm run lint && npm run lint:deps:strict && npm run check:depcruise-baseline && npm run stylelint && npm run build && npm run check:seo-prerender && npm run test:ci:app && npm run check:i18n",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "stylelint '**/*.{css,scss}' --fix",
        "prettier": "prettier --check '**/*.{js,ts,css,scss,html,json,md}'",
        "prettier:fix": "prettier --write '**/*.{js,ts,css,scss,html,json,md}'",
        "test": "ng test",
        "test:ci": "ng test --watch=false",
        "test:ci:app": "ng test food-diary-web-client --watch=false",
        "test:ci:ui-kit": "ng test fd-ui-kit --watch=false",
        "test:ci:admin": "ng test fooddiary-admin --watch=false",
        "test:coverage": "npm run test:coverage:app && npm run test:coverage:ui-kit && npm run test:coverage:admin",
        "test:coverage:app": "ng test food-diary-web-client --watch=false --coverage",
        "test:coverage:ui-kit": "ng test fd-ui-kit --watch=false --coverage",
        "test:coverage:admin": "ng test fooddiary-admin --watch=false --coverage",
        "check:i18n": "node scripts/check-i18n.mjs",
        "check:seo-prerender": "node scripts/check-prerender-html.mjs",
        "test:e2e:client:smoke": "npx playwright test -c playwright.client.smoke.config.ts",
        "test:e2e:client:smoke:ui": "npx playwright test -c playwright.client.smoke.config.ts --ui",
        "test:e2e:admin:smoke": "npx playwright test -c playwright.admin.smoke.config.ts",
        "test:e2e:admin:smoke:ui": "npx playwright test -c playwright.admin.smoke.config.ts --ui",
        "audit:lighthouse:collect": "node scripts/run-lighthouse.mjs",
        "audit:lighthouse": "npm run build:audit && npm run audit:lighthouse:collect",
        "storybook": "ng run fd-ui-kit:storybook",
        "build:storybook": "ng run fd-ui-kit:build-storybook",
        "serve:ssr:food-diary-web-client": "node dist/server/server.mjs"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^22.0.0",
        "@angular/cdk": "^22.0.0",
        "@angular/common": "^22.0.0",
        "@angular/compiler": "^22.0.0",
        "@angular/core": "^22.0.0",
        "@angular/forms": "^22.0.0",
        "@angular/platform-browser": "^22.0.0",
        "@angular/platform-browser-dynamic": "^22.0.0",
        "@angular/platform-server": "^22.0.0",
        "@angular/router": "^22.0.0",
        "@angular/service-worker": "^22.0.0",
        "@angular/ssr": "^22.0.0",
        "@microsoft/signalr": "^10.0.0",
        "@ngx-translate/core": "^17.0.0",
        "@ngx-translate/http-loader": "^17.0.0",
        "express": "^5.2.1",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^22.0.0",
        "@angular-eslint/eslint-plugin": "^22.0.0",
        "@angular-eslint/eslint-plugin-template": "^22.0.0",
        "@angular-eslint/template-parser": "^22.0.0",
        "@angular/build": "^22.0.0",
        "@angular/cli": "^22.0.0",
        "@angular/compiler-cli": "^22.0.0",
        "@emnapi/core": "^1.10.0",
        "@emnapi/runtime": "^1.10.0",
        "@emnapi/wasi-threads": "^1.2.1",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@lhci/cli": "^0.15.1",
        "@material-design-icons/font": "^0.14.15",
        "@playwright/test": "^1.60.0",
        "@storybook/angular": "^10.4.2",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.2",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "@vitest/coverage-v8": "^4.1.8",
        "angular-eslint": "^22.0.0",
        "baseline-browser-mapping": "^2.10.34",
        "concurrently": "^10.0.3",
        "dependency-cruiser": "^17.4.3",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-rxjs-x": "^1.0.2",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-storybook": "10.4.2",
        "eslint-plugin-unicorn": "^65.0.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "ng-morph": "^5.0.0",
        "ng-packagr": "^22.0.0",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.3",
        "storybook": "^10.4.2",
        "stylelint": "^17.13.0",
        "stylelint-config-clean-order": "^10.0.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-scss": "^7.2.0",
        "typescript": "6.0.3",
        "vitest": "^4.1.8"
    }
}
