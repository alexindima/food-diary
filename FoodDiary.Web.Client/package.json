{
    "name": "food-diary-web-client",
    "version": "0.0.0",
    "type": "module",
    "overrides": {
        "minimatch": "^9.0.5"
    },
    "scripts": {
        "prepare": "cd .. && husky FoodDiary.Web.Client/.husky",
        "ng": "ng",
        "build": "ng build",
        "build:prod": "ng build --configuration=production",
        "build:staging": "ng build --configuration=staging",
        "build:admin": "ng build fooddiary-admin",
        "start": "ng serve --configuration=development",
        "start:tunnel": "ng serve --configuration=tunnel",
        "tunnel": "cloudflared tunnel run fooddiary-local",
        "start:tunnel:all": "concurrently -k -n web,tunnel -c green,blue \"npm:start:tunnel\" \"npm:tunnel\"",
        "start:prod": "ng serve --configuration=production",
        "start:staging": "ng serve --configuration=staging",
        "start:admin": "ng serve fooddiary-admin",
        "watch": "ng build --watch --configuration development",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "stylelint '**/*.{css,scss}' --fix",
        "prettier": "prettier --check '**/*.{js,ts,css,scss,html,json,md}'",
        "prettier:fix": "prettier --write '**/*.{js,ts,css,scss,html,json,md}'",
        "test": "ng test",
        "test:ci": "ng test --watch=false",
        "check:i18n": "node scripts/check-i18n.mjs",
        "test:e2e:client:smoke": "npx playwright test -c playwright.client.smoke.config.ts",
        "test:e2e:client:smoke:ui": "npx playwright test -c playwright.client.smoke.config.ts --ui",
        "test:e2e:admin:smoke": "npx playwright test -c playwright.admin.smoke.config.ts",
        "test:e2e:admin:smoke:ui": "npx playwright test -c playwright.admin.smoke.config.ts --ui",
        "audit:lighthouse:collect": "node scripts/run-lighthouse.mjs",
        "audit:lighthouse": "npm run build:prod && npm run audit:lighthouse:collect",
        "storybook": "ng run fd-ui-kit:storybook",
        "build:storybook": "ng run fd-ui-kit:build-storybook",
        "serve:ssr:food-diary-web-client": "node dist/server/server.mjs"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^21.2.10",
        "@angular/cdk": "^21.2.8",
        "@angular/common": "^21.2.10",
        "@angular/compiler": "^21.2.10",
        "@angular/core": "^21.2.10",
        "@angular/forms": "^21.2.10",
        "@angular/platform-browser": "^21.2.10",
        "@angular/platform-browser-dynamic": "^21.2.10",
        "@angular/platform-server": "^21.2.10",
        "@angular/router": "^21.2.10",
        "@angular/service-worker": "^21.2.10",
        "@angular/ssr": "^21.2.7",
        "@microsoft/signalr": "^10.0.0",
        "@ngx-translate/core": "^17.0.0",
        "@ngx-translate/http-loader": "^17.0.0",
        "chart.js": "^4.5.1",
        "cropperjs": "^2.1.1",
        "express": "^5.1.0",
        "ng2-charts": "^10.0.0",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^21.2.8",
        "@angular-eslint/eslint-plugin-template": "^21.3.1",
        "@angular-eslint/template-parser": "^21.3.1",
        "@angular/build": "^21.2.5",
        "@angular/cli": "^21.2.8",
        "@angular/compiler-cli": "^21.2.10",
        "@angular/platform-server": "^21.2.10",
        "@angular/ssr": "^21.2.7",
        "@emnapi/core": "^1.10.0",
        "@emnapi/runtime": "^1.9.2",
        "@emnapi/wasi-threads": "^1.2.0",
        "@lhci/cli": "^0.15.1",
        "@material-design-icons/font": "^0.14.15",
        "@playwright/test": "^1.59.1",
        "@storybook/angular": "^10.3.5",
        "@types/express": "^5.0.1",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "angular-eslint": "^21.3.1",
        "baseline-browser-mapping": "^2.10.23",
        "concurrently": "^9.2.1",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "jsdom": "^29.0.2",
        "ng-morph": "^5.0.0",
        "ng-packagr": "^21.2.3",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.3",
        "storybook": "^10.3.4",
        "stylelint": "^17.9.0",
        "stylelint-config-clean-order": "^8.0.1",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^8.1.1",
        "typescript": "5.9",
        "vitest": "^4.1.5"
    }
}
