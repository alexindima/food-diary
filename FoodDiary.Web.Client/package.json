{
  "name": "food-diary-web-client",
  "version": "0.0.0",
  "type": "module",
  "overrides": {
    "minimatch": "^9.0.5"
  },
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "build:staging": "ng build --configuration=staging",
    "build:admin": "ng build fooddiary-admin",
    "start": "ng serve",
    "start:prod": "ng serve --configuration=production",
    "start:staging": "ng serve --configuration=staging",
    "start:admin": "ng serve fooddiary-admin",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint '**/*.{css,scss}'",
    "stylelint:fix": "stylelint '**/*.{css,scss}' --fix",
    "prettier": "prettier --check '**/*.{js,ts,css,scss,html,json,md}'",
    "prettier:fix": "prettier --write '**/*.{js,ts,css,scss,html,json,md}'",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@angular/service-worker": "^21.2.6",
    "@microsoft/signalr": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "@zxing/ngx-scanner": "^21.0.0",
    "chart.js": "^4.5.1",
    "cropperjs": "^2.1.0",
    "ng2-charts": "^10.0.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.6",
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "@emnapi/wasi-threads": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "baseline-browser-mapping": "^2.10.12",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.1",
    "ng-morph": "^4.8.4",
    "ng-packagr": "^21.2.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "5.9",
    "vitest": "^4.1.2"
  }
