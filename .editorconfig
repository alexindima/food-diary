root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# C# backend style: K&R braces (opening brace on the same line)
csharp_new_line_before_open_brace = none
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false

# Prefer modern C# shape consistently across backend projects.
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_style_prefer_primary_constructors = true:suggestion
csharp_prefer_braces = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_method_group_conversion = true:suggestion
csharp_style_prefer_top_level_statements = false:none

# Keep type style readable: use var only when the assigned type is obvious.
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_elsewhere = false:suggestion

# Keep expression bodies conservative; they are useful for small members, noisy for methods.
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_methods = false:none
csharp_style_expression_bodied_constructors = false:none

# General .NET style rules enforced by dotnet format/build.
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = false:none
dotnet_style_prefer_conditional_expression_over_return = false:none

# Analyzer rollout: add third-party analyzers, then promote individual rules as the codebase is cleaned up.
dotnet_analyzer_diagnostic.category-Roslynator.severity = suggestion
dotnet_analyzer_diagnostic.category-Meziantou.Analyzer.severity = suggestion
dotnet_diagnostic.MA0002.severity = warning
dotnet_diagnostic.MA0004.severity = warning
dotnet_diagnostic.MA0006.severity = warning
dotnet_diagnostic.MA0008.severity = warning
dotnet_diagnostic.MA0009.severity = warning
dotnet_diagnostic.MA0011.severity = warning
dotnet_diagnostic.MA0015.severity = warning
dotnet_diagnostic.MA0016.severity = warning
dotnet_diagnostic.MA0047.severity = warning
dotnet_diagnostic.MA0048.severity = suggestion
dotnet_diagnostic.MA0049.severity = suggestion
dotnet_diagnostic.MA0051.severity = suggestion
dotnet_diagnostic.MA0061.severity = warning
dotnet_diagnostic.MA0074.severity = warning
dotnet_diagnostic.MA0132.severity = warning
dotnet_diagnostic.MA0144.severity = warning
dotnet_diagnostic.MA0150.severity = warning
dotnet_diagnostic.IDE0005.severity = warning

# Keep analyzers strict without forcing noisy public API or logging migrations in one pass.
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.CA1716.severity = none
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1859.severity = none

[FoodDiary.Domain/**/*.cs]
dotnet_diagnostic.MA0051.severity = warning

[FoodDiary.MailInbox.Domain/**/*.cs]
dotnet_diagnostic.MA0051.severity = warning

[FoodDiary.MailRelay.Domain/**/*.cs]
dotnet_diagnostic.MA0051.severity = warning

[FoodDiary.Application.Abstractions/**/*.cs]
