ASPNETCORE_ENVIRONMENT=Production
IMAGE_PREFIX=ghcr.io/alexindima/food-diary
# Recommended server location: /etc/fooddiary/fooddiary.env

# Database
POSTGRES_DB=fooddiary
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=fooddiary;Username=postgres;Password=

# JWT authentication
Jwt__SecretKey=
Jwt__Issuer=fooddiary.club
Jwt__Audience=fooddiary.club
Jwt__ExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=30
Cors__Origins__0=https://fooddiary.club
Cors__Origins__1=https://www.fooddiary.club
Cors__Origins__2=https://admin.fooddiary.club

# S3-compatible storage
S3__Region=
S3__Bucket=
S3__PublicBaseUrl=
S3__ServiceUrl=
S3__AccessKeyId=
S3__SecretAccessKey=

# Telegram
TelegramAuth__BotToken=
TelegramBot__ApiSecret=
TelegramBot__Token=
TelegramBot__ApiBaseUrl=
TelegramBot__WebAppUrl=

# OpenAI
OpenAi__ApiKey=

# Billing
Billing__Provider=Stripe

# Stripe
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=
Stripe__PremiumMonthlyPriceId=
Stripe__PremiumYearlyPriceId=
Stripe__SuccessUrl=http://localhost:4200/premium?checkout=success&session_id={CHECKOUT_SESSION_ID}
Stripe__CancelUrl=http://localhost:4200/premium?checkout=canceled
Stripe__PortalReturnUrl=http://localhost:4200/premium

# Paddle
Paddle__ApiKey=
Paddle__ApiBaseUrl=https://sandbox-api.paddle.com
Paddle__ClientSideToken=
Paddle__WebhookSecretKey=
Paddle__PremiumMonthlyPriceId=
Paddle__PremiumYearlyPriceId=
Paddle__CheckoutUrl=http://localhost:4200/premium

# OpenTelemetry (optional, leave empty to disable; applies to API and MailRelay)
OpenTelemetry__Otlp__Endpoint=

# Email (SMTP)
Email__SmtpHost=
Email__SmtpPort=587
Email__SmtpUser=
Email__SmtpPassword=
Email__FromAddress=
Email__FrontendBaseUrl=
Email__AllowedFrontendBaseUrls__0=https://fooddiary.club
Email__AllowedFrontendBaseUrls__1=https://дневникеды.рф
Email__AllowedFrontendBaseUrls__2=https://www.дневникеды.рф
Email__AllowedFrontendBaseUrls__3=https://xn--b1adbcbrouc8l.xn--p1ai
Email__AllowedFrontendBaseUrls__4=https://www.xn--b1adbcbrouc8l.xn--p1ai
EmailDelivery__Mode=Smtp
EmailDelivery__RelayBaseUrl=http://mail-relay:5088
EmailDelivery__RelayApiKey=

# Mail relay
MAIL_RELAY_IMAGE_TAG=latest
MAIL_RELAY_PORT=5088
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MailRelay__RequireApiKey=false
MailRelay__ApiKey=
MailRelayQueue__PollIntervalSeconds=5
MailRelayQueue__BatchSize=10
MailRelayQueue__MaxAttempts=6
MailRelayQueue__BaseRetryDelaySeconds=30
MailRelayQueue__MaxRetryDelaySeconds=1800
MailRelayQueue__LockTimeoutSeconds=120
MailRelayBroker__Backend=RabbitMq
MailRelayBroker__HostName=rabbitmq
MailRelayBroker__Port=5672
MailRelayBroker__UserName=guest
MailRelayBroker__Password=guest
MailRelayBroker__VirtualHost=/
MailRelayBroker__QueueName=fooddiary.mailrelay.outbound
MailRelayBroker__OutboundExchangeName=fooddiary.mailrelay
MailRelayBroker__OutboundRoutingKey=outbound
MailRelayBroker__RetryExchangeName=fooddiary.mailrelay.retry
MailRelayBroker__RetryQueueName=fooddiary.mailrelay.outbound.retry
MailRelayBroker__RetryRoutingKey=retry
MailRelayBroker__RetryDelayMilliseconds=30000
MailRelayBroker__DeadLetterExchangeName=fooddiary.mailrelay.dead
MailRelayBroker__DeadLetterQueueName=fooddiary.mailrelay.outbound.dead
MailRelayBroker__DeadLetterRoutingKey=dead
MailRelayBroker__PrefetchCount=10
MailRelayBroker__EnablePollingFallback=true
RelaySmtp__Host=
RelaySmtp__Port=587
RelaySmtp__UseSsl=true
RelaySmtp__User=
RelaySmtp__Password=
MailRelayDelivery__Mode=SmtpSubmission
DirectMx__Port=25
DirectMx__ConnectTimeoutSeconds=20
DirectMx__UseStartTlsWhenAvailable=true
MailRelayDkim__Enabled=false
MailRelayDkim__Domain=
MailRelayDkim__Selector=
MailRelayDkim__PrivateKeyPem=
MailRelayDkim__PrivateKeyPath=
MAIL_RELAY_DKIM_PRIVATE_KEY_FILE=

# Mail inbox
MAIL_INBOX_IMAGE_TAG=latest
MAIL_INBOX_INITIALIZER_IMAGE_TAG=latest
MAIL_INBOX_POSTGRES_DB=fooddiary_mailinbox
MAIL_INBOX_POSTGRES_USER=postgres
MAIL_INBOX_POSTGRES_PASSWORD=
MAIL_INBOX_POSTGRES_PORT=5434
MAIL_INBOX_PORT=5098
MAIL_INBOX_SMTP_PORT=25
MailInboxSmtp__Enabled=true
MailInboxSmtp__ServerName=mail.fooddiary.club
MailInboxSmtp__Port=2525
MailInboxSmtp__AllowedRecipients__0=admin@fooddiary.club
MailInboxSmtp__AllowedRecipients__1=dmarc@fooddiary.club
MailInboxSmtp__AllowedRecipients__2=feedback@fooddiary.club
MailInboxSmtp__AllowedRecipients__3=support@fooddiary.club
