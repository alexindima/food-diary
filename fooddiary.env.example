ASPNETCORE_ENVIRONMENT=Production

# Database
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=fooddiary;Username=postgres;Password=

# JWT authentication
Jwt__SecretKey=
Jwt__Issuer=fooddiary.club
Jwt__Audience=fooddiary.club
Jwt__ExpirationMinutes=60
Jwt__RefreshTokenExpirationDays=30

# S3-compatible storage
S3__Region=
S3__Bucket=
S3__PublicBaseUrl=
S3__ServiceUrl=
S3__AccessKeyId=
S3__SecretAccessKey=

# Telegram
TelegramAuth__BotToken=
TelegramBot__ApiSecret=
TelegramBot__Token=
TelegramBot__ApiBaseUrl=
TelegramBot__WebAppUrl=

# OpenAI
OpenAi__ApiKey=

# OpenTelemetry (optional, leave empty to disable)
OpenTelemetry__Otlp__Endpoint=

# Email (SMTP)
Email__SmtpHost=
Email__SmtpPort=587
Email__SmtpUser=
Email__SmtpPassword=
Email__FromAddress=
Email__FrontendBaseUrl=
