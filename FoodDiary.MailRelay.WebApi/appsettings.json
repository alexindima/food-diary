{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=fooddiary_mailrelay;Username=postgres;Password=change-me-local-password"
  },
  "MailRelay": {
    "RequireApiKey": false,
    "ApiKey": ""
  },
  "MailRelayQueue": {
    "PollIntervalSeconds": 5,
    "BatchSize": 10,
    "MaxAttempts": 6,
    "BaseRetryDelaySeconds": 30,
    "MaxRetryDelaySeconds": 1800,
    "LockTimeoutSeconds": 120
  },
  "MailRelayBroker": {
    "Backend": "RabbitMq",
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "QueueName": "fooddiary.mailrelay.outbound",
    "OutboundExchangeName": "fooddiary.mailrelay",
    "OutboundRoutingKey": "outbound",
    "RetryExchangeName": "fooddiary.mailrelay.retry",
    "RetryQueueName": "fooddiary.mailrelay.outbound.retry",
    "RetryRoutingKey": "retry",
    "RetryDelayMilliseconds": 30000,
    "DeadLetterExchangeName": "fooddiary.mailrelay.dead",
    "DeadLetterQueueName": "fooddiary.mailrelay.outbound.dead",
    "DeadLetterRoutingKey": "dead",
    "PrefetchCount": 10,
    "EnablePollingFallback": true
  },
  "RelaySmtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": true,
    "User": "",
    "Password": ""
  },
  "MailRelayDelivery": {
    "Mode": "SmtpSubmission"
  },
  "DirectMx": {
    "Port": 25,
    "ConnectTimeoutSeconds": 20,
    "UseStartTlsWhenAvailable": true
  },
  "MailRelayDkim": {
    "Enabled": false,
    "Domain": "",
    "Selector": "",
    "PrivateKeyPem": "",
    "PrivateKeyPath": ""
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
