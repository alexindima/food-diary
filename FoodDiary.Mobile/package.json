{
    "name": "food-diary-mobile",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build:web": "npm --prefix ../FoodDiary.Web.Client run build",
        "copy": "cap copy",
        "sync": "cap sync",
        "sync:android": "npm run build:web && cap sync android",
        "android:gradle": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/android-gradle.ps1",
        "build:android:debug": "npm run sync:android && npm run android:gradle -- assembleDebug",
        "open:android": "cap open android",
        "doctor": "cap doctor"
    },
    "dependencies": {
        "@capacitor/android": "8.4.0",
        "@capacitor/core": "8.4.0",
        "@capgo/capacitor-social-login": "^8.3.22"
    },
    "devDependencies": {
        "@capacitor/cli": "8.4.0",
        "typescript": "6.0.3"
    }
}
