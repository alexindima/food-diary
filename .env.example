# Database
POSTGRES_DB=fooddiary
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-password
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_PORT=5432
REDIS_PORT=6379
IMAGE_PREFIX=ghcr.io/alexindima/food-diary

# API
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Production

# Client
CLIENT_PORT=4200

# Secrets (override appsettings.json via environment variables)
# Jwt__SecretKey=your-secret-key-at-least-32-chars
# Jwt__RememberMeRefreshTokenExpirationDays=90
# ConnectionStrings__Redis=redis:6379,abortConnect=false
# InitialAdmin__Email=admin@fooddiary.club
# InitialAdmin__Password=change-me-strong-initial-admin-password
# S3__AccessKeyId=
# S3__SecretAccessKey=
# S3__Region=
# S3__Bucket=
# S3__ServiceUrl=
# S3__PublicBaseUrl=
# TelegramAuth__BotToken=
# TelegramBot__Token=
# TelegramBot__WebAppUrl=
# TelegramBot__ApiBaseUrl=http://api:5000
# TelegramBot__ApiSecret=
# OpenAi__ApiKey=
# Email__SmtpHost=
# Email__SmtpUser=
# Email__SmtpPassword=
# DirectMx__LocalDomain=mail.fooddiary.club
# MailRelay__ApiKey=change-me-shared-mail-relay-api-key
# MailRelay__MailgunWebhookSigningKey=change-me-mailgun-webhook-signing-key
# MailRelayClient__ApiKey=change-me-shared-mail-relay-api-key
# MailInboxHttp__ApiKey=change-me-shared-mail-inbox-api-key
# MailInboxClient__ApiKey=change-me-shared-mail-inbox-api-key
# OpenTelemetry__Otlp__Endpoint=http://host.docker.internal:4317

# Mail inbox
MAIL_RELAY_POSTGRES_DB=fooddiary_mailrelay
MAIL_RELAY_POSTGRES_USER=postgres
MAIL_RELAY_POSTGRES_PASSWORD=change-me-local-password
MAIL_RELAY_POSTGRES_HOST_BIND=127.0.0.1
MAIL_RELAY_POSTGRES_PORT=5433
MAIL_INBOX_POSTGRES_DB=fooddiary_mailinbox
MAIL_INBOX_POSTGRES_USER=postgres
MAIL_INBOX_POSTGRES_PASSWORD=change-me-local-password
MAIL_INBOX_POSTGRES_HOST_BIND=127.0.0.1
MAIL_INBOX_POSTGRES_PORT=5434
MAIL_INBOX_PORT=5098
MAIL_INBOX_SMTP_PORT=2525
# MailInboxSmtp__Enabled=true
# MailInboxSmtp__ServerName=mail.fooddiary.club
# MailInboxSmtp__Port=2525
