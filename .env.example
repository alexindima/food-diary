# Database
POSTGRES_DB=fooddiary
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-password
POSTGRES_PORT=5432
IMAGE_PREFIX=ghcr.io/alexindima/food-diary

# API
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Production

# Client
CLIENT_PORT=4200

# Secrets (override appsettings.json via environment variables)
# Jwt__SecretKey=your-secret-key-at-least-32-chars
# S3__AccessKeyId=
# S3__SecretAccessKey=
# S3__Region=
# S3__Bucket=
# S3__ServiceUrl=
# S3__PublicBaseUrl=
# TelegramAuth__BotToken=
# TelegramBot__Token=
# TelegramBot__WebAppUrl=
# TelegramBot__ApiBaseUrl=http://api:5000
# TelegramBot__ApiSecret=
# OpenAi__ApiKey=
# Email__SmtpHost=
# Email__SmtpUser=
# Email__SmtpPassword=
